{
  "compilerOptions": {
    "rootDir": "./src",
    "target": "ES2020",
    "types": ["node"],
    "lib": ["esnext"],
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "exclude": ["node_modules", "tests", "dist"]
}
